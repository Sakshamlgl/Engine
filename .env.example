# ── Required ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=         # free: console.groq.com

# ── Stock media (need at least one) ──────────────────────────────────────────
PIXABAY_API_KEY=        # free: pixabay.com/api/docs
PEXELS_API_KEY=          # free: pexels.com/api
UNSPLASH_ACCESS_KEY=                   # optional: unsplash.com/developers

# ── Phase 4: Grok image generation (xAI) ─────────────────────────────────────
# Required for Tier-1 AI fallback images when vision score is low.
# Get your key at https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ── Phase 4 flags ─────────────────────────────────────────────────────────────
LLM_ASSET_RANKING=false          # true = smarter ranking, costs tokens
POLLINATIONS_ENABLED=true        # true = AI image fallback (no key needed)
POLLINATIONS_TIMEOUT=25          # seconds to wait for AI image
IMAGE_TO_VIDEO_PROVIDER=         # Phase 15: kling | runway | luma | (empty)

# ── v4 Story Brain ────────────────────────────────────────────────────────────
# Central LLM feedback loop — scores every fetched asset and re-fetches weak ones.
# Uses Groq (llama-3.3-70b) — same key as above, no extra cost beyond tokens.
STORY_BRAIN_ENABLED=true
STORY_BRAIN_THRESHOLD=42         # 0-100: below this score = weak asset
STORY_BRAIN_MAX_RETRIES=2        # how many times to re-fetch a weak scene

# ── v4 Shot Planning ──────────────────────────────────────────────────────────
# Expands each scene into a professional multi-shot sequence:
#   hook → wide + close
#   discovery → wide + close + reaction
#   climax → wide + close + reaction + detail
SHOT_PLANNING_ENABLED=true
SHOT_PLANNING_MAX=4              # max shots per scene (2-4 recommended)

# ── v4 Sequencer ─────────────────────────────────────────────────────────────
# Enforces deliberate image→video→image alternating rhythm.
# Climax scenes are sandwiched: image → climax video → image.
SEQUENCER_ENABLED=true
SEQUENCER_VIDEO_CADENCE=2        # every 2nd shot = video (1=all video, 3=less video)
SEQUENCER_CLIMAX_SANDWICH=true   # wrap climax videos with image bookends

# ── v4 Visual Verifier ────────────────────────────────────────────────────────
# Uses Groq's free vision model (llama-3.2-11b-vision) to physically look at
# each downloaded asset and reject ones that don't match the scene.
# Adds ~1-2s per scene, no extra API cost.
VISUAL_VERIFY_ENABLED=true
VISUAL_VERIFY_THRESHOLD=35       # 0-100: below this = rejected, try next candidate

# ══════════════════════════════════════════════════════════
# v5 UPGRADE FLAGS
# ══════════════════════════════════════════════════════════

# CLIP Retrieval — semantic ranking (highest ROI)
# Requires: pip install sentence-transformers (or open_clip_torch)
CLIP_ENABLED=true
CLIP_WEIGHT=0.55        # 0-1: how much CLIP influences final score

# Story Brain Vision — Story Brain SEES the actual image
# Uses the same Groq key as visual_verifier (no extra cost)
STORY_BRAIN_VISION_ENABLED=true

# Editing Intelligence — beat-aware cut decisions
EDITING_INTELLIGENCE_ENABLED=true
EDITING_INTELLIGENCE_LLM=true   # use LLM for climax/discovery beats (small token cost)

# Character Face Embeddings — embedding-based visual consistency
CHARACTER_EMBED_ENABLED=true
# For true face embeddings (highest accuracy): pip install insightface

# ══════════════════════════════════════════════════════════
# NEW Phase 1–4 FLAGS (per implementation plan)
# ══════════════════════════════════════════════════════════
# XAI_API_KEY         — needed for Grok image gen fallback (see image_generator.py)
# VISUAL_VERIFY_THRESHOLD is now default 50 (stricter → more AI images when stock is marginal)
#
# Audio Reviewer requires: pydub + system ffmpeg
# Bensound uses requests + beautifulsoup4 (has static fallback)
# NASA + Wikimedia are public APIs (no keys)
